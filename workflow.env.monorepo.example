# workflow.env — Monorepo Example
# Copy to .github/workflow.env and adjust values for your repo.
# Run: bash bin/app git workflow-setup --apply

# Required — all types
WORKFLOW_TYPE=monorepo
REPO_OWNER=edotz
REPO_NAME=my-monorepo
RELEASE_TYPE=node             # node | php | simple

# Required — monorepo
MAIN_BRANCH=master
RELEASE_BRANCH=1.x
STATUS_CHECKS="commit-lint,biome"  # comma-separated: commit-lint | biome | php-cs-fixer | shellcheck
PACKAGES_DIR=packages         # directory containing package subdirs, each with .github/workflow.env

# Optional
STAGE=production              # production (default): strict enforcement, PRs required for all
                               # development: relaxes MAIN_BRANCH protection (bypass ohoeft, no enforce_admins)
                               #              /git:promote does direct --no-ff merge, skipping status checks
LEGACY_BRANCHES=              # comma-separated legacy release branches, e.g. 0.x — empty if none
PROJECT_TYPE=node             # defaults to RELEASE_TYPE; passed to generate-readme-action (node|php|typo3|boilerplate|childrepo)
BACKPORT_FILES=               # override default backport files (leave empty to use defaults per RELEASE_TYPE)
