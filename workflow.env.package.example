# workflow.env — Package Example (place in packages/<name>/.github/workflow.env)
# Each package in a monorepo gets its own workflow.env.
# Run: bash bin/app git workflow-setup --apply (from monorepo root)

# Required — all types
WORKFLOW_TYPE=package
REPO_OWNER=edotz
REPO_NAME=my-package          # childrepo name on GitHub
RELEASE_TYPE=node             # node | php | simple

# Required — package
MONOREPO_REPO=edotz/my-monorepo   # GitHub repo of the parent monorepo
MONOREPO_PACKAGE=my-package        # package directory name under PACKAGES_DIR

# Optional
STAGE=production              # production (default): strict enforcement, PRs required for all
                               # development: relaxes MAIN_BRANCH protection (bypass ohoeft, no enforce_admins)
                               #              /git:promote does direct --no-ff merge, skipping status checks
LEGACY_BRANCHES=              # comma-separated legacy release branches — inherited from monorepo if unset
PROJECT_TYPE=childrepo        # defaults to RELEASE_TYPE; passed to generate-readme-action (node|php|typo3|boilerplate|childrepo)
PACKAGE_NAME=@edotz/my-pkg    # node only — npm package name
BACKPORT_FILES=               # override default backport files (leave empty to use defaults per RELEASE_TYPE)
